{
  "name": "@clevertap/native-display-sdk",
  "version": "0.1.0",
  "description": "CleverTap Native Display SDK for React Native - server-driven native UI from JSON",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "keywords": [
    "clevertap",
    "react-native",
    "native-display",
    "server-driven-ui",
    "sdk"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "clevertap-react-native": ">=4.1.0",
    "react-native-linear-gradient": ">=2.8.0",
    "react-native-svg": ">=15.0.0",
    "react-native-reanimated": ">=3.5.0",
    "react-native-webview": ">=13.7.0",
    "react-native-video": ">=6.0.0",
    "@react-native-masked-view/masked-view": ">=0.3.0",
    "expo-image": ">=1.10.0",
    "react-native-fast-image": ">=8.6.0",
    "@react-native-community/blur": ">=4.4.0"
  },
  "peerDependenciesMeta": {
    "clevertap-react-native": { "optional": true },
    "react-native-linear-gradient": { "optional": true },
    "react-native-svg": { "optional": true },
    "react-native-reanimated": { "optional": true },
    "react-native-webview": { "optional": true },
    "react-native-video": { "optional": true },
    "@react-native-masked-view/masked-view": { "optional": true },
    "expo-image": { "optional": true },
    "react-native-fast-image": { "optional": true },
    "@react-native-community/blur": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.3.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts", "**/__tests__/**/*.test.tsx"],
    "moduleFileExtensions": ["ts", "tsx", "js", "json"],
    "transform": {
      "^.+\\.(ts|tsx)$": ["ts-jest", {
        "tsconfig": {
          "jsx": "react"
        }
      }]
    },
    "moduleNameMapper": {
      "react-native": "<rootDir>/__mocks__/react-native.js"
    }
  }
}
