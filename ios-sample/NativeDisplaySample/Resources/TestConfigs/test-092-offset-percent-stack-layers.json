          "backgroundColor": "#FFFFFF",
          "borderWidth": 1,
          "borderColor": "#CCCCCC"
        },
        "children": [
          {
            "type": "container",
            "id": "layer-0",
            "containerType": "box",
            "layout": {
              "width": {
                "value": 100,
                "unit": "dp"
              },
              "height": {
                "value": 100,
                "unit": "dp"
              },
              "offset": {
                "x": 0,
                "y": 0,
                "unit": "percent"
              }
            },
            "style": {
              "backgroundColor": "#2196F3",
              "opacity": 0.8
            },
            "children": []
          },
          {
            "type": "container",
            "id": "layer-25",
