{
  "root": {
    "type": "container",
    "id": "root",
    "containerType": "box",
    "layout": {
      "width": { "special": "match_parent" },
      "height": { "value": 300, "unit": "dp" }
    },
    "children": [
      {
        "type": "element",
        "id": "bg-image",
        "elementType": "image",
        "bindings": {
          "url": "https://picsum.photos/800/300"
        },
        "layout": {
          "width": { "special": "match_parent" },
          "height": { "special": "match_parent" }
        }
      },
      {
        "type": "element",
        "id": "html-overlay",
        "elementType": "html",
        "bindings": {
          "html": "<div style='padding: 24px; font-family: -apple-system, sans-serif;'><h1 style='color: white; text-shadow: 2px 2px 4px rgba(0,0,0,0.8); margin: 0 0 8px 0; font-size: 28px;'>Transparent Overlay</h1><p style='color: rgba(255,255,255,0.9); text-shadow: 1px 1px 3px rgba(0,0,0,0.6); margin: 0; font-size: 16px; line-height: 1.5;'>This HTML element has a transparent background, allowing the image behind it to show through.</p></div>"
        },
        "htmlConfig": {
          "transparentBackground": true,
          "scrollEnabled": false
        },
        "layout": {
          "width": { "special": "match_parent" },
          "height": { "special": "match_parent" }
        }
      }
    ]
  }
}
