              },
              {
                "type": "element",
                "id": "title",
                "elementType": "text",
                "bindings": {
                  "text": "Premium Wireless Headphones"
                },
                "layout": {
                  "width": {
                    "value": 100,
                    "unit": "percent"
                  },
                  "height": {
                    "value": 0,
                    "unit": "dp",
                    "special": "wrap_content"
                  }
                },
                "style": {
                  "fontSize": 22,
                  "fontWeight": "bold",
                  "textColor": "#000000",
                  "lineHeight": 29
