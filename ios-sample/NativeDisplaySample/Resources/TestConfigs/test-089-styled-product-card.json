                "layout": {
                  "width": {
                    "value": 100,
                    "unit": "percent"
                  },
                  "height": {
                    "value": 0,
                    "unit": "dp",
                    "special": "wrap_content"
                  }
                },
                "style": {
                  "fontSize": 14,
                  "textColor": "#666666",
                  "lineHeight": 21
                }
