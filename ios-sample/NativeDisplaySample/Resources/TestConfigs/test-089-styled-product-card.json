                    "type": "element",
                    "id": "heart-icon",
                    "elementType": "text",
                    "bindings": {
                      "text": "♥"
                    },
                    "layout": {
                      "width": {
                        "value": 0,
                        "unit": "dp",
                        "special": "wrap_content"
                      },
                      "height": {
                        "value": 0,
                        "unit": "dp",
                        "special": "wrap_content"
                      }
                    },
                    "style": {
                      "fontSize": 20,
                      "textColor": "#E91E63",
                      "lineHeight": 28
