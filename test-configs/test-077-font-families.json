{
  "theme": {
    "id": "font-families-theme",
    "defaultStyle": {
      "fontSize": 16,
      "textColor": "#333333",
      "fontWeight": "normal"
    }
  },
  "root": {
    "id": "font-families-root",
    "containerType": "vertical",
    "layout": {
      "width": { "value": 100, "unit": "percent" },
      "height": { "value": 100, "unit": "percent" },
      "padding": { "all": 20 },
      "arrangement": { "strategy": "SPACED", "value": 20 }
    },
    "style": {
      "backgroundColor": "#FAFAFA"
    },
    "children": [
      {
        "id": "title",
        "elementType": "text",
        "bindings": {
          "text": "Font Family Variations"
        },
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": "wrap_content", "unit": "dp" }
        },
        "style": {
          "fontSize": 26,
          "fontWeight": "bold",
          "textAlign": "center",
          "textColor": "#1565C0"
        }
      },
      {
        "id": "system-container",
        "containerType": "vertical",
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": "wrap_content", "unit": "dp" },
          "padding": { "all": 16 },
          "arrangement": { "strategy": "SPACED", "value": 8 }
        },
        "style": {
          "backgroundColor": "#FFFFFF",
          "borderRadius": 8,
          "borderWidth": 1,
          "borderColor": "#E0E0E0"
        },
        "children": [
          {
            "id": "system-label",
            "elementType": "text",
            "bindings": {
              "text": "System (default):"
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
              "fontSize": 14,
              "fontWeight": "medium",
              "textColor": "#757575"
            }
          },
          {
            "id": "system-text",
            "elementType": "text",
            "bindings": {
              "text": "This text uses the system default font. The quick brown fox jumps over the lazy dog. 0123456789"
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
              "fontFamily": "system",
              "fontSize": 16
            }
          }
        ]
      },
      {
        "id": "monospace-container",
        "containerType": "vertical",
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": "wrap_content", "unit": "dp" },
          "padding": { "all": 16 },
          "arrangement": { "strategy": "SPACED", "value": 8 }
        },
        "style": {
          "backgroundColor": "#FFFFFF",
          "borderRadius": 8,
          "borderWidth": 1,
          "borderColor": "#E0E0E0"
        },
        "children": [
          {
            "id": "monospace-label",
            "elementType": "text",
            "bindings": {
              "text": "Monospace (fixed-width):"
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
              "fontSize": 14,
              "fontWeight": "medium",
              "textColor": "#757575"
            }
          },
          {
            "id": "monospace-text",
            "elementType": "text",
            "bindings": {
              "text": "Monospace font for code. function() { return true; } 0123456789"
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
              "fontFamily": "monospace",
              "fontSize": 14,
              "backgroundColor": "#F5F5F5"
            }
          }
        ]
      },
      {
        "id": "serif-container",
        "containerType": "vertical",
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": "wrap_content", "unit": "dp" },
          "padding": { "all": 16 },
          "arrangement": { "strategy": "SPACED", "value": 8 }
        },
        "style": {
          "backgroundColor": "#FFFFFF",
          "borderRadius": 8,
          "borderWidth": 1,
          "borderColor": "#E0E0E0"
        },
        "children": [
          {
            "id": "serif-label",
            "elementType": "text",
            "bindings": {
              "text": "Serif (traditional):"
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
              "fontSize": 14,
              "fontWeight": "medium",
              "textColor": "#757575"
            }
          },
          {
            "id": "serif-text",
            "elementType": "text",
            "bindings": {
              "text": "This text uses a serif font for a more traditional, elegant appearance. Perfect for long-form reading content."
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
              "fontFamily": "serif",
              "fontSize": 16,
              "lineHeight": 1.6
            }
          }
        ]
      },
      {
        "id": "comparison",
        "containerType": "vertical",
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": "wrap_content", "unit": "dp" },
          "padding": { "all": 16 },
          "arrangement": { "strategy": "SPACED", "value": 12 }
        },
        "style": {
          "backgroundColor": "#E3F2FD",
          "borderRadius": 8
        },
        "children": [
          {
            "id": "comp-title",
            "elementType": "text",
            "bindings": {
              "text": "Quick Comparison:"
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
              "fontSize": 14,
              "fontWeight": "bold",
              "textColor": "#1565C0"
            }
          },
          {
            "id": "comp-system",
            "elementType": "text",
            "bindings": {
              "text": "System: ABC abc 123"
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
              "fontFamily": "system",
              "fontSize": 18
            }
          },
          {
            "id": "comp-monospace",
            "elementType": "text",
            "bindings": {
              "text": "Monospace: ABC abc 123"
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
              "fontFamily": "monospace",
              "fontSize": 18
            }
          },
          {
            "id": "comp-serif",
            "elementType": "text",
            "bindings": {
              "text": "Serif: ABC abc 123"
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
              "fontFamily": "serif",
              "fontSize": 18
            }
          }
        ]
      },
      {
        "id": "code-example",
        "elementType": "text",
        "bindings": {
          "text": "if (condition) {\n  console.log('Monospace is ideal for code');\n  return value;\n}"
        },
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": "wrap_content", "unit": "dp" }
        },
        "style": {
          "fontFamily": "monospace",
          "fontSize": 14,
          "backgroundColor": "#263238",
          "textColor": "#AAAAAA",
          "borderRadius": 8
        }
      }
    ]
  }
}
