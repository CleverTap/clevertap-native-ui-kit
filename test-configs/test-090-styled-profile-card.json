{
  "theme": {
    "id": "profile-theme",
    "defaultStyle": {
      "fontSize": 14,
      "textColor": "#333333",
      "fontWeight": "normal",
      "lineHeight": 1.4
    }
  },
  "styleClasses": [
    {
      "id": "stat-value",
      "style": {
        "fontSize": 24,
        "fontWeight": "bold",
        "textColor": "#000000"
      }
    },
    {
      "id": "stat-label",
      "style": {
        "fontSize": 12,
        "textColor": "#999999"
      }
    },
    {
      "id": "action-button",
      "style": {
        "backgroundColor": "#2196F3",
        "textColor": "#FFFFFF",
        "fontSize": 14,
        "fontWeight": "bold",
        "borderRadius": 20,
        "shadowColor": "#2196F3",
        "shadowOpacity": 0.25,
        "shadowRadius": 8,
        "shadowOffsetX": 0,
        "shadowOffsetY": 4
      }
    }
  ],
  "root": {
    "id": "profile-root",
    "containerType": "vertical",
    "layout": {
      "width": { "value": 100, "unit": "percent" },
      "height": { "value": 100, "unit": "percent" },
      "padding": { "all": 20 },
      "arrangement": { "strategy": "CENTER" }
    },
    "style": {
      "backgroundColor": "#F0F4F8"
    },
    "children": [
      {
        "id": "profile-card",
        "containerType": "vertical",
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": "wrap_content", "unit": "dp" },
          "padding": { "all": 0 },
          "arrangement": { "strategy": "START" }
        },
        "style": {
          "backgroundColor": "#FFFFFF",
          "borderRadius": 20,
          "shadowColor": "#000000",
          "shadowOpacity": 0.15,
          "shadowRadius": 16,
          "shadowOffsetX": 0,
          "shadowOffsetY": 8
        },
        "children": [
          {
            "id": "header-background",
            "containerType": "stack",
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": 150, "unit": "dp" }
            },
            "children": [
              {
                "id": "gradient-bg",
                "elementType": "image",
                "bindings": {
                  "src": "https://picsum.photos/400/300"
                },
                "layout": {
                  "width": { "value": 100, "unit": "percent" },
                  "height": { "value": 150, "unit": "dp" }
                },
                "style": {
                  "borderRadius": 20,
                  "opacity": 0.8
                }
              },
              {
                "id": "overlay",
                "containerType": "box",
                "layout": {
                  "width": { "value": 100, "unit": "percent" },
                  "height": { "value": 150, "unit": "dp" }
                },
                "style": {
                  "backgroundColor": "#2196F3",
                  "opacity": 0.7,
                  "borderRadius": 20
                },
                "children": []
              },
              {
                "id": "verified-badge",
                "containerType": "box",
                "layout": {
                  "width": { "value": "wrap_content", "unit": "dp" },
                  "height": { "value": "wrap_content", "unit": "dp" },
                  "padding": { "horizontal": 12, "vertical": 6 },
                  "offset": { "x": -16, "y": 16 }
                },
                "style": {
                  "backgroundColor": "#4CAF50",
                  "borderRadius": 12,
                  "shadowColor": "#4CAF50",
                  "shadowOpacity": 0.4,
                  "shadowRadius": 8,
                  "shadowOffsetX": 0,
                  "shadowOffsetY": 4
                },
                "children": [
                  {
                    "id": "verified-text",
                    "elementType": "text",
                    "bindings": {
                      "text": "✓ Verified"
                    },
                    "layout": {
                      "width": { "value": "wrap_content", "unit": "dp" },
                      "height": { "value": "wrap_content", "unit": "dp" }
                    },
                    "style": {
                      "fontSize": 12,
                      "fontWeight": "bold",
                      "textColor": "#FFFFFF"
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "profile-content",
            "containerType": "vertical",
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" },
              "padding": { "all": 24 },
              "arrangement": { "strategy": "SPACED", "value": 20 }
            },
            "children": [
              {
                "id": "avatar-section",
                "containerType": "vertical",
                "layout": {
                  "width": { "value": 100, "unit": "percent" },
                  "height": { "value": "wrap_content", "unit": "dp" },
                  "arrangement": { "strategy": "CENTER" }
                },
                "children": [
                  {
                    "id": "avatar-container",
                    "containerType": "box",
                    "layout": {
                      "width": { "value": 100, "unit": "dp" },
                      "height": { "value": 100, "unit": "dp" }
                    },
                    "style": {
                      "backgroundColor": "#E3F2FD",
                      "borderRadius": 50,
                      "borderWidth": 4,
                      "borderColor": "#FFFFFF",
                      "shadowColor": "#000000",
                      "shadowOpacity": 0.2,
                      "shadowRadius": 12,
                      "shadowOffsetX": 0,
                      "shadowOffsetY": 6
                    },
                    "children": [
                      {
                        "id": "avatar-initials",
                        "elementType": "text",
                        "bindings": {
                          "text": "AJ"
                        },
                        "layout": {
                          "width": { "value": "wrap_content", "unit": "dp" },
                          "height": { "value": "wrap_content", "unit": "dp" }
                        },
                        "style": {
                          "fontSize": 40,
                          "fontWeight": "bold",
                          "textColor": "#2196F3"
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "id": "name-section",
                "containerType": "vertical",
                "layout": {
                  "width": { "value": 100, "unit": "percent" },
                  "height": { "value": "wrap_content", "unit": "dp" },
                  "arrangement": { "strategy": "CENTER", "value": 4 }
                },
                "children": [
                  {
                    "id": "name",
                    "elementType": "text",
                    "bindings": {
                      "text": "Alex Johnson"
                    },
                    "layout": {
                      "width": { "value": 100, "unit": "percent" },
                      "height": { "value": "wrap_content", "unit": "dp" }
                    },
                    "style": {
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "textAlign": "center",
                      "textColor": "#000000"
                    }
                  },
                  {
                    "id": "username",
                    "elementType": "text",
                    "bindings": {
                      "text": "@alexj"
                    },
                    "layout": {
                      "width": { "value": 100, "unit": "percent" },
                      "height": { "value": "wrap_content", "unit": "dp" }
                    },
                    "style": {
                      "fontSize": 16,
                      "textAlign": "center",
                      "textColor": "#2196F3"
                    }
                  }
                ]
              },
              {
                "id": "bio",
                "elementType": "text",
                "bindings": {
                  "text": "Product Designer | Travel Enthusiast | Coffee Lover ☕️ Sharing my journey through design and life."
                },
                "layout": {
                  "width": { "value": 100, "unit": "percent" },
                  "height": { "value": "wrap_content", "unit": "dp" }
                },
                "style": {
                  "fontSize": 14,
                  "textAlign": "center",
                  "textColor": "#666666",
                  "lineHeight": 1.6
                }
              },
              {
                "id": "stats-container",
                "containerType": "horizontal",
                "layout": {
                  "width": { "value": 100, "unit": "percent" },
                  "height": { "value": "wrap_content", "unit": "dp" },
                  "padding": { "vertical": 16 },
                  "arrangement": { "strategy": "SPACE_EVENLY" }
                },
                "style": {
                  "backgroundColor": "#F5F5F5",
                  "borderRadius": 12
                },
                "children": [
                  {
                    "id": "posts-stat",
                    "containerType": "vertical",
                    "layout": {
                      "width": { "value": "wrap_content", "unit": "dp" },
                      "height": { "value": "wrap_content", "unit": "dp" },
                      "arrangement": { "strategy": "CENTER", "value": 4 }
                    },
                    "children": [
                      {
                        "id": "posts-value",
                        "elementType": "text",
                        "bindings": {
                          "text": "1,247"
                        },
                        "layout": {
                          "width": { "value": "wrap_content", "unit": "dp" },
                          "height": { "value": "wrap_content", "unit": "dp" }
                        },
                        "styleClass": "stat-value"
                      },
                      {
                        "id": "posts-label",
                        "elementType": "text",
                        "bindings": {
                          "text": "Posts"
                        },
                        "layout": {
                          "width": { "value": "wrap_content", "unit": "dp" },
                          "height": { "value": "wrap_content", "unit": "dp" }
                        },
                        "styleClass": "stat-label"
                      }
                    ]
                  },
                  {
                    "id": "followers-stat",
                    "containerType": "vertical",
                    "layout": {
                      "width": { "value": "wrap_content", "unit": "dp" },
                      "height": { "value": "wrap_content", "unit": "dp" },
                      "arrangement": { "strategy": "CENTER", "value": 4 }
                    },
                    "children": [
                      {
                        "id": "followers-value",
                        "elementType": "text",
                        "bindings": {
                          "text": "42.5K"
                        },
                        "layout": {
                          "width": { "value": "wrap_content", "unit": "dp" },
                          "height": { "value": "wrap_content", "unit": "dp" }
                        },
                        "styleClass": "stat-value"
                      },
                      {
                        "id": "followers-label",
                        "elementType": "text",
                        "bindings": {
                          "text": "Followers"
                        },
                        "layout": {
                          "width": { "value": "wrap_content", "unit": "dp" },
                          "height": { "value": "wrap_content", "unit": "dp" }
                        },
                        "styleClass": "stat-label"
                      }
                    ]
                  },
                  {
                    "id": "following-stat",
                    "containerType": "vertical",
                    "layout": {
                      "width": { "value": "wrap_content", "unit": "dp" },
                      "height": { "value": "wrap_content", "unit": "dp" },
                      "arrangement": { "strategy": "CENTER", "value": 4 }
                    },
                    "children": [
                      {
                        "id": "following-value",
                        "elementType": "text",
                        "bindings": {
                          "text": "892"
                        },
                        "layout": {
                          "width": { "value": "wrap_content", "unit": "dp" },
                          "height": { "value": "wrap_content", "unit": "dp" }
                        },
                        "styleClass": "stat-value"
                      },
                      {
                        "id": "following-label",
                        "elementType": "text",
                        "bindings": {
                          "text": "Following"
                        },
                        "layout": {
                          "width": { "value": "wrap_content", "unit": "dp" },
                          "height": { "value": "wrap_content", "unit": "dp" }
                        },
                        "styleClass": "stat-label"
                      }
                    ]
                  }
                ]
              },
              {
                "id": "divider",
                "elementType": "divider",
                "layout": {
                  "width": { "value": 100, "unit": "percent" },
                  "height": { "value": 1, "unit": "dp" }
                },
                "style": {
                  "backgroundColor": "#E0E0E0"
                }
              },
              {
                "id": "action-buttons",
                "containerType": "horizontal",
                "layout": {
                  "width": { "value": 100, "unit": "percent" },
                  "height": { "value": 48, "unit": "dp" },
                  "arrangement": { "strategy": "SPACED", "value": 12 }
                },
                "children": [
                  {
                    "id": "follow-button",
                    "containerType": "box",
                    "layout": {
                      "width": { "value": 0, "unit": "percent", "weight": 1 },
                      "height": { "value": 48, "unit": "dp" },
                      "padding": { "all": 12 }
                    },
                    "styleClass": "action-button",
                    "children": [
                      {
                        "id": "follow-text",
                        "elementType": "text",
                        "bindings": {
                          "text": "Follow"
                        },
                        "layout": {
                          "width": { "value": "wrap_content", "unit": "dp" },
                          "height": { "value": "wrap_content", "unit": "dp" }
                        }
                      }
                    ]
                  },
                  {
                    "id": "message-button",
                    "containerType": "box",
                    "layout": {
                      "width": { "value": 0, "unit": "percent", "weight": 1 },
                      "height": { "value": 48, "unit": "dp" },
                      "padding": { "all": 12 }
                    },
                    "style": {
                      "backgroundColor": "#FFFFFF",
                      "borderRadius": 20,
                      "borderWidth": 2,
                      "borderColor": "#2196F3"
                    },
                    "children": [
                      {
                        "id": "message-text",
                        "elementType": "text",
                        "bindings": {
                          "text": "Message"
                        },
                        "layout": {
                          "width": { "value": "wrap_content", "unit": "dp" },
                          "height": { "value": "wrap_content", "unit": "dp" }
                        },
                        "style": {
                          "fontSize": 14,
                          "fontWeight": "bold",
                          "textColor": "#2196F3"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
