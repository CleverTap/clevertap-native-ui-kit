{
  "theme": {
    "id": "test-theme",
    "defaultStyle": {
      "textColor": "#2E7D32",
      "fontSize": 16
    }
  },
  "root": {
    "type": "container",
    "id": "vertical-space-between",
    "containerType": "vertical",
