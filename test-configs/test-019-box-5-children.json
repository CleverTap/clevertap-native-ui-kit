      },
      {
        "type": "element",
        "id": "bottom-button",
        "elementType": "button",
        "bindings": {
          "text": "Learn More"
        },
        "layout": {
          "width": {
            "value": 200,
            "unit": "dp"
          },
          "height": {
            "value": 50,
            "unit": "dp"
          },
          "offset": {
            "x": 50,
            "y": 32,
            "unit": "percent"
          }
        },
        "style": {
          "backgroundColor": "#0288D1",
          "textColor": "#FFFFFF",
          "fontSize": 18,
          "fontWeight": "bold",
          "borderRadius": 25
