{
  "theme": {
    "id": "summer-sale",
    "defaultStyle": { "textColor": "#FFFFFFFF", "fontSize": 16, "lineHeight": 22 }
  },
  "variables": {
    "headline": "Summer Sale",
    "subtext": "Up to 50% off on selected items",
    "cta": "Shop Now",
    "bgImage": "https://yavuzceliker.github.io/sample-images/image-2.jpg"
  },
  "root": {
    "id": "root",
    "type": "container",
    "containerType": "box",
    "layout": {
      "width": { "value": 100, "unit": "percent" },
      "height": { "value": 200, "unit": "dp" }
    },
    "children": [
      {
        "id": "bg",
        "type": "element",
        "elementType": "image",
        "bindings": { "url": "{{bgImage}}" },
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": 200, "unit": "dp" }
        }
      },
      {
        "id": "overlay",
        "type": "container",
        "containerType": "vertical",
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": 200, "unit": "dp" },
          "padding": { "all": 20 },
          "arrangement": { "strategy": "center" }
        },
        "style": { "background": { "type": "linear_gradient", "colors": ["#88000000", "#BB000000"], "angle": 180 } },
        "children": [
          {
            "id": "headline",
            "type": "element",
            "elementType": "text",
            "bindings": { "text": "{{headline}}" },
            "layout": { "width": { "value": 100, "unit": "percent" } },
            "style": { "fontSize": 32, "fontWeight": "bold", "textAlign": "center", "lineHeight": 40 }
          },
          {
            "id": "subtext",
            "type": "element",
            "elementType": "text",
            "bindings": { "text": "{{subtext}}" },
            "layout": { "width": { "value": 100, "unit": "percent" }, "padding": { "top": 8 } },
            "style": { "fontSize": 16, "textAlign": "center", "lineHeight": 22 }
          },
          {
            "id": "cta",
            "type": "element",
            "elementType": "button",
            "bindings": { "text": "{{cta}}" },
            "layout": { "width": { "value": 160, "unit": "dp" }, "height": { "value": 44, "unit": "dp" }, "padding": { "top": 16 } },
            "style": { "backgroundColor": "#FFFF6B35", "borderRadius": 22, "fontSize": 15, "fontWeight": "bold", "lineHeight": 20 }
          }
        ]
      }
    ]
  }
}
