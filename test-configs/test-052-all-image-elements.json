{
  "theme": {
    "id": "image-grid",
    "defaultStyle": {
      "textColor": "#000000",
      "fontSize": 14
    }
  },
  "root": {
    "id": "image-grid-container",
    "containerType": "vertical",
    "layout": {
      "width": { "value": 100, "unit": "percent" },
      "height": { "value": 100, "unit": "percent" },
      "padding": { "all": 16 },
      "arrangement": {
        "type": "spaced",
        "spacing": 12
      }
    },
    "style": {
      "backgroundColor": "#000000"
    },
    "children": [
      {
        "id": "row-1",
        "containerType": "horizontal",
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": 180, "unit": "dp" },
          "arrangement": {
            "type": "spaced",
            "spacing": 12
          }
        },
        "children": [
          {
            "id": "image-1",
            "elementType": "image",
            "bindings": {
              "src": "https://picsum.photos/400/400?random=1"
            },
            "layout": {
              "width": { "value": 50, "unit": "percent" },
              "height": { "value": 100, "unit": "percent" }
            },
            "style": {
              "borderRadius": 8
            }
          },
          {
            "id": "image-2",
            "elementType": "image",
            "bindings": {
              "src": "https://picsum.photos/400/400?random=2"
            },
            "layout": {
              "width": { "value": 50, "unit": "percent" },
              "height": { "value": 100, "unit": "percent" }
            },
            "style": {
              "borderRadius": 8
            }
          }
        ]
      },
      {
        "id": "row-2",
        "containerType": "horizontal",
        "layout": {
          "width": { "value": 100, "unit": "percent" },
          "height": { "value": 180, "unit": "dp" },
          "arrangement": {
            "type": "spaced",
            "spacing": 12
          }
        },
        "children": [
          {
            "id": "image-3",
            "elementType": "image",
            "bindings": {
              "src": "https://picsum.photos/400/400?random=3"
            },
            "layout": {
              "width": { "value": 50, "unit": "percent" },
              "height": { "value": 100, "unit": "percent" }
            },
            "style": {
              "borderRadius": 8
            }
          },
          {
            "id": "image-4",
            "elementType": "image",
            "bindings": {
              "src": "https://picsum.photos/400/400?random=4"
            },
            "layout": {
              "width": { "value": 50, "unit": "percent" },
              "height": { "value": 100, "unit": "percent" }
            },
            "style": {
              "borderRadius": 8
            }
          }
        ]
      }
    ]
  }
}