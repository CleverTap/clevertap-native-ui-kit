            "elementType": "text",
            "bindings": {
              "text": "Light shadows are perfect for cards, buttons, and floating elements that need subtle depth without overwhelming the design."
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
