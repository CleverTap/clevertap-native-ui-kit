            }
          },
          {
            "id": "shadow-1-desc",
            "elementType": "text",
            "bindings": {
              "text": "Shadow: opacity 0.1, radius 2, offset (0, 1)"
            },
            "layout": {
              "width": { "value": 100, "unit": "percent" },
              "height": { "value": "wrap_content", "unit": "dp" }
            },
            "style": {
