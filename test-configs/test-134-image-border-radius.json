{
  "theme": {
    "id": "test-134"
  },
  "root": {
    "type": "container",
    "id": "root",
    "containerType": "box",
    "layout": {
      "width": {"value": 100, "unit": "percent"},
      "aspectRatio": 1.333
    },
    "style": {
      "backgroundColor": "#F0F0F0"
    },
    "children": [
      {
        "type": "container",
        "id": "rounded_frame",
        "containerType": "box",
        "layout": {
          "width": {"value": 80, "unit": "percent"},
          "height": {"value": 70, "unit": "percent"},
          "offset": {"x": 10, "y": 10, "unit": "percent"}
        },
        "style": {
          "borderRadius": 20,
          "backgroundColor": "#FFFFFF"
        },
        "children": [
          {
            "type": "element",
            "id": "rounded_image",
            "elementType": "image",
            "bindings": {
              "url": "https://yavuzceliker.github.io/sample-images/image-300.jpg"
            },
            "layout": {
              "width": {"value": 100, "unit": "percent"},
              "height": {"value": 100, "unit": "percent"}
            }
          }
        ]
      },
      {
        "type": "element",
        "id": "label",
        "elementType": "text",
        "bindings": {
          "text": "Rounded Image"
        },
        "layout": {
          "width": {"value": 40, "unit": "percent"},
          "offset": {"x": 5, "y": 5, "unit": "percent"}
        },
        "style": {
          "fontSize": 11,
          "fontWeight": "bold",
          "lineHeight": 15,
          "textColor": "#FFFFFF",
          "backgroundColor": "#333333AA",
          "borderRadius": 4
        }
      }
    ]
  }
}
