{
  "theme": {
    "id": "test-theme",
    "defaultStyle": {
      "textColor": "#212121",
      "fontSize": 16
    }
  },
  "root": {
    "id": "vertical-single",
    "containerType": "vertical",
    "layout": {
      "width": {
        "value": 100,
        "unit": "percent"
      },
      "height": {
        "value": 300,
        "unit": "dp"
      },
      "padding": {
        "all": 20
      },
      "arrangement": {
        "strategy": "center",
        "spacing": 0
      }
    },
    "style": {
      "background": {
        "type": "linear_gradient",
        "angle": 135,
        "colors": ["#667EEA", "#764BA2"]
      }
    },
    "children": [
      {
        "id": "title",
        "elementType": "text",
        "bindings": {
          "text": "Welcome to Native Display"
        },
        "layout": {
          "width": {
            "value": 100,
            "unit": "percent"
          },
          "height": {
            "value": "wrap_content",
            "unit": "dp"
          }
        },
        "style": {
          "fontSize": 28,
          "fontWeight": "bold",
          "textColor": "#FFFFFF",
          "textAlign": "center"
        }
      }
    ]
  }
}
