{
  "theme": {
    "id": "test-114",
    "defaultStyle": {
      "textColor": "#000000",
      "fontSize": 14,
      "lineHeight": 20
    }
  },
  "variables": {
    "testName": "Combined - E-Commerce Product Grid"
  },
