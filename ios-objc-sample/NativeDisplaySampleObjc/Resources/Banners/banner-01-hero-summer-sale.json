            "bindings": { "text": "+" },
            "style": {
              "fontSize": 28,
              "textColor": "#FFFFFF"
            }
          },
          {
            "type": "element",
            "id": "app-title",
            "elementType": "text",
            "bindings": { "text": "Instagram " },
            "style": {
              "fontSize": 24,
              "textColor":"#FF0000",
              "fontFamily": "Arial",
              "fontWeight": "light",
              "fontStyle": "italic",
              "fontWeight": "bold",
              "textColor": "#FFFFFF00",
              "maxLines": 1,
              "letterSpacing": 10,
              "textAlign": "left",
              "textShadow": {
                "color": "#FF000000",
                "radius": 8,
                "offsetX": 0,
                "offsetY": 4,
                "blur": 5
              },
              "textGradient": {
                  "colors": ["#FF000000", "#FFFF0000"],
                  "type": "linear",
                  "angle": 0,
                  "stops": [0.2, 0.6]
              }
            }
          },
          {
            "type": "element",
            "id": "heart-icon",
            "elementType": "text",
            "bindings": { "text": "\u2661" },
            "style": {
              "fontSize": 24,
              "textColor": "#FFFFFF"
            }
          }
        ]
      },

      {
        "type": "element",
        "id": "divider-top",
