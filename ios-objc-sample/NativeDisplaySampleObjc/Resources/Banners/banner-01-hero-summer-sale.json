  "variables": {
    "username_1": "Your story",
    "username_2": "utkarshakamthe",
    "username_3": "snehal.shinde_21",
    "username_4": "_harshad0...",
    "post_user": "instantbollywood",
    "post_music": "Sachin-Jigar, Vishal Mishra, Amitabh Bhattacharya, S...",
