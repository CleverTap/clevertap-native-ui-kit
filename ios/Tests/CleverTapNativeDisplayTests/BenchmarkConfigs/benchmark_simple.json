{
  "theme": {
    "id": "default",
    "defaultStyle": {
      "textColor": "#333333",
      "fontSize": 14,
      "lineHeight": 20
    }
  },
  "styleClasses": [
    {
      "name": "heading",
      "style": {
        "fontSize": 20,
        "fontWeight": "bold",
        "lineHeight": 28
      }
    }
  ],
  "root": {
    "type": "container",
    "id": "root",
    "containerType": "vertical",
    "layout": {
      "width": {"value": 100, "unit": "percent"},
      "padding": {"all": 16}
    },
    "style": {
      "backgroundColor": "#FFFFFF",
      "borderRadius": 8
    },
    "children": [
      {
        "type": "element",
        "id": "title",
        "elementType": "text",
        "bindings": {"text": "Card Title"},
        "styleClass": "heading"
      },
      {
        "type": "element",
        "id": "spacer-1",
        "elementType": "spacer",
        "bindings": {},
        "layout": {"height": {"value": 8, "unit": "dp"}}
      },
      {
        "type": "element",
        "id": "subtitle",
        "elementType": "text",
        "bindings": {"text": "A simple subtitle"},
        "style": {"textColor": "#666666"}
      },
      {
        "type": "element",
        "id": "spacer-2",
        "elementType": "spacer",
        "bindings": {},
        "layout": {"height": {"value": 12, "unit": "dp"}}
      },
      {
        "type": "container",
        "id": "button-row",
        "containerType": "horizontal",
        "layout": {
          "arrangement": {"strategy": "end"}
        },
        "children": [
          {
            "type": "element",
            "id": "btn-action",
            "elementType": "button",
            "bindings": {"text": "Action"},
            "style": {
              "backgroundColor": "#2196F3",
              "textColor": "#FFFFFF",
              "borderRadius": 4
            },
            "layout": {
              "padding": {"horizontal": 16, "vertical": 8}
            }
          }
        ]
      }
    ]
  }
}
