{
  "theme": {
    "id": "default",
    "defaultStyle": {
      "textColor": "#333333",
      "fontSize": 14,
      "lineHeight": 20
    }
  },
  "styleClasses": [
    {
      "name": "heading",
      "style": {
        "fontSize": 20,
        "lineHeight": 28,
        "fontWeight": "bold",
        "textColor": "#000000"
      }
    }
  ],
  "variables": {},
  "root": {
    "type": "container",
    "id": "root",
    "containerType": "vertical",
    "layout": {
      "width": {"special": "match_parent"},
      "padding": {"all": 16},
      "arrangement": {"strategy": "spaced", "spacing": 12}
    },
    "style": {
      "backgroundColor": "#FFFFFF"
    },
    "children": [
      {
        "type": "element",
        "id": "title",
        "elementType": "text",
        "bindings": {"text": "Simple Benchmark"},
        "styleClass": "heading"
      },
      {
        "type": "element",
        "id": "image_1",
        "elementType": "image",
        "bindings": {"url": "https://picsum.photos/400/200"},
        "layout": {
          "width": {"special": "match_parent"},
          "aspectRatio": 2.0
        },
        "style": {
          "borderRadius": 8
        }
      },
      {
        "type": "element",
        "id": "desc",
        "elementType": "text",
        "bindings": {"text": "A simple card layout with an image and description text for benchmarking."}
      },
      {
        "type": "container",
        "id": "button_row",
        "containerType": "horizontal",
        "layout": {
          "width": {"special": "match_parent"},
          "arrangement": {"strategy": "space_between"}
        },
        "children": [
          {
            "type": "element",
            "id": "btn_cancel",
            "elementType": "button",
            "bindings": {"text": "Cancel"},
            "layout": {
              "padding": {"horizontal": 24, "vertical": 10}
            },
            "style": {
              "backgroundColor": "#E0E0E0",
              "borderRadius": 8,
              "textColor": "#333333"
            }
          },
          {
            "type": "element",
            "id": "btn_confirm",
            "elementType": "button",
            "bindings": {"text": "Confirm"},
            "layout": {
              "padding": {"horizontal": 24, "vertical": 10}
            },
            "style": {
              "backgroundColor": "#FF5722",
              "borderRadius": 8,
              "textColor": "#FFFFFF"
            }
          }
        ]
      }
    ]
  }
}
