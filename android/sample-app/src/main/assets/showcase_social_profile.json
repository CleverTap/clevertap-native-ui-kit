                    "elementType": "text",
                    "bindings": {
                      "text": "Interests"
                    },
                    "style": {
                      "textColor": "#1A1A1A",
                      "fontSize": 16,
                      "fontWeight": "bold"
                    }
                  },
                  {
                    "type": "container",
                    "id": "interests_tags",
                    "containerType": "horizontal",
                    "layout": {
                      "spacing": 8
                    },
                    "children": [
                      {
                        "type": "container",
                        "id": "tag_design",
                        "containerType": "box",
                        "layout": {
                          "padding": {
                            "vertical": 8,
                            "horizontal": 16
