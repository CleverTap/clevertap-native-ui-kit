                          }
                        ]
                      },
                      {
                        "type": "container",
                        "id": "tag_creative",
                        "containerType": "box",
                        "layout": {
                          "padding": {
                            "vertical": 8,
                            "horizontal": 16
                          }
                        },
                        "style": {
                          "backgroundColor": "#FFF3E0",
                          "borderRadius": 16,
                          "opacity": 0.9
                        },
                        "children": [
                          {
                            "type": "element",
                            "id": "tag_creative_text",
                            "elementType": "text",
