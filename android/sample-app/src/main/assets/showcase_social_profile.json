                        "style": {
                          "textColor": "#666666",
                          "fontSize": 12,
                          "textAlign": "center",
                          "opacity": 0.8
                        }
                      }
                    ]
                  },
                  {
                    "type": "element",
                    "id": "stat_divider_2",
                    "elementType": "divider",
                    "dividerConfig": {
                      "orientation": "vertical",
                      "thickness": 1,
                      "color": "#E0E0E0"
                    }
                  },
                  {
                    "type": "container",
                    "id": "posts_stat",
                    "containerType": "vertical",
                    "layout": {
                      "spacing": 4,
                      "padding": {
                        "horizontal": 16
                      }
                    },
                    "children": [
                      {
                        "type": "element",
                        "id": "posts_count",
                        "elementType": "text",
                        "bindings": {
                          "text": "234"
                        },
                        "style": {
                          "textColor": "#1A1A1A",
                          "fontSize": 20,
                          "fontWeight": "bold",
                          "textAlign": "center"
                        }
                      },
                      {
                        "type": "element",
                        "id": "posts_label",
                        "elementType": "text",
                        "bindings": {
                          "text": "Posts"
                        },
                        "style": {
                          "textColor": "#666666",
                          "fontSize": 12,
                          "textAlign": "center",
                          "opacity": 0.8
                        }
                      }
                    ]
                  }
                ]
              },
