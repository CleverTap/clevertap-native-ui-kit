<?xml version="1.0" encoding="utf-8"?>
<!--
  XML parallel of the Compose `AppContentCard` in SlotDemoScreen.kt.

  Uses androidx CardView (not MaterialCardView) because the sample activity's
  theme is android:Theme.Material.Light.NoActionBar — the framework Material
  theme — not Theme.MaterialComponents.*. MaterialCardView/MaterialButton
  require the AndroidX Material Components theme tree on the inflating context
  and crash on inflate without it. CardView has no theme requirement.

  - 12dp rounded corners
  - 2dp elevation
  - 180dp image at top
  - Title + subtitle below with 12dp padding
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/contentImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="#EEEEEE"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/contentTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/contentSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#888888"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
