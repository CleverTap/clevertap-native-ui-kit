          "textColor": "#1A237E",
          "fontSize": 24,
          "fontWeight": "bold",
          "textAlign": "center"
        },
        "layout": {
          "padding": {
            "bottom": 8
          }
        },
        "animation": {
          "type": "slide_in_left",
          "duration": 300,
          "delay": 0,
          "easing": "ease_out"
        }
      },
      {
        "type": "element",
        "id": "stagger_subtitle",
