          "width": { "value": 100, "unit": "percent" }
        },
        "style": {
          "fontSize": 18,
          "fontWeight": "bold",
          "textColor": "#333333"
        }
      },
      {
        "type": "element",
        "id": "description",
        "elementType": "text",
