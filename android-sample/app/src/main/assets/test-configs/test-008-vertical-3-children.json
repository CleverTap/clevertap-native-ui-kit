{
  "theme": {
    "id": "test-theme",
    "defaultStyle": {
      "textColor": "#424242",
      "fontSize": 16
    }
  },
  "root": {
    "id": "vertical-3-children",
    "containerType": "vertical",
    "layout": {
      "width": {
        "value": 100,
        "unit": "percent"
      },
      "height": {
        "value": 500,
        "unit": "dp"
      },
      "padding": {
        "all": 16
      },
      "arrangement": {
        "strategy": "space_between",
        "spacing": 0
      }
    },
    "style": {
      "backgroundColor": "#FFF3E0",
      "borderRadius": 16
    },
    "children": [
      {
        "id": "header",
        "elementType": "text",
        "bindings": {
          "text": "Product Showcase"
        },
        "layout": {
          "width": {
            "value": 100,
            "unit": "percent"
          },
          "height": {
            "value": "wrap_content",
            "unit": "dp"
          }
        },
        "style": {
          "fontSize": 24,
          "fontWeight": "bold",
          "textColor": "#E65100"
        }
      },
      {
        "id": "product-image",
        "elementType": "image",
        "bindings": {
          "src": "https://picsum.photos/400/300"
        },
        "layout": {
          "width": {
            "value": 100,
            "unit": "percent"
          },
          "height": {
            "value": 300,
            "unit": "dp"
          }
        },
        "style": {
          "borderRadius": 12
        }
      },
      {
        "id": "description",
        "elementType": "text",
        "bindings": {
          "text": "Discover our premium collection of handcrafted items"
        },
        "layout": {
          "width": {
            "value": 100,
            "unit": "percent"
          },
          "height": {
            "value": "wrap_content",
            "unit": "dp"
          }
        },
        "style": {
          "fontSize": 16,
          "textColor": "#5D4037",
          "lineHeight": 24
        }
      }
    ]
  }
}
