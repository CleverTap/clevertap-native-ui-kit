{
  "theme": {
    "id": "test-theme",
    "defaultStyle": {
      "textColor": "#1B5E20",
      "fontSize": 14
    }
  },
  "root": {
    "type": "container",
    "id": "box-3-children",
    "containerType": "box",
    "layout": {
      "width": {
        "value": 100,
        "unit": "percent"
      },
      "height": {
        "value": 500,
        "unit": "dp"
      },
      "padding": {
        "all": 0
      }
    },
    "style": {
      "background": {
        "type": "linear_gradient",
        "angle": 135,
        "colors": [
          "#A5D6A7",
          "#66BB6A",
          "#2E7D32"
        ]
      }
    },
    "children": [
      {
        "type": "element",
        "id": "top-left",
        "elementType": "text",
        "bindings": {
          "text": "Top Left"
        },
        "layout": {
          "width": {
            "value": 0,
            "unit": "dp",
            "special": "wrap_content"
          },
          "height": {
            "value": 0,
            "unit": "dp",
            "special": "wrap_content"
          },
          "padding": {
            "all": 12
          },
          "offset": {
            "x": 16,
            "y": 16,
            "unit": "dp"
          }
        },
        "style": {
          "backgroundColor": "#FFFFFF",
          "textColor": "#1B5E20",
          "fontSize": 18,
          "fontWeight": "bold",
          "borderRadius": 8
        }
      },
      {
        "type": "element",
        "id": "center",
        "elementType": "image",
        "bindings": {
          "url": "https://picsum.photos/200/200"
        },
        "layout": {
          "width": {
            "value": 200,
            "unit": "dp"
          },
          "height": {
            "value": 200,
            "unit": "dp"
          },
          "offset": {
            "x": 50,
            "y": 50,
            "unit": "percent"
          }
        },
        "style": {
          "borderRadius": 100,
          "borderWidth": 4,
          "borderColor": "#FFFFFF"
        }
      },
      {
        "type": "element",
        "id": "bottom-right",
        "elementType": "text",
        "bindings": {
          "text": "Bottom Right"
        },
        "layout": {
          "width": {
            "value": 0,
            "unit": "dp",
            "special": "wrap_content"
          },
          "height": {
            "value": 0,
            "unit": "dp",
            "special": "wrap_content"
          },
          "padding": {
            "all": 12
          },
          "offset": {
            "x": 16,
            "y": 16,
            "unit": "dp"
          }
        },
        "style": {
          "backgroundColor": "#FFFFFF",
          "textColor": "#1B5E20",
          "fontSize": 18,
          "fontWeight": "bold",
          "borderRadius": 8
        }
