{
  "theme": {
    "id": "test-theme",
    "defaultStyle": {
      "textColor": "#D84315",
      "fontSize": 16
    }
  },
  "root": {
    "id": "vertical-wrap-content",
    "containerType": "vertical",
    "layout": {
      "width": {
        "value": 100,
        "unit": "percent"
      },
      "height": {
        "value": "wrap_content",
        "unit": "dp"
      },
      "padding": {
        "all": 20
      },
      "arrangement": {
        "strategy": "spaced",
        "spacing": 16
      }
    },
    "style": {
      "backgroundColor": "#FBE9E7",
      "borderRadius": 16
    },
    "children": [
      {
        "id": "header",
        "elementType": "text",
        "bindings": {
          "text": "WRAP_CONTENT Height"
        },
        "layout": {
          "width": {
            "value": 100,
            "unit": "percent"
          },
          "height": {
            "value": "wrap_content",
            "unit": "dp"
          }
        },
        "style": {
          "fontSize": 26,
          "fontWeight": "bold",
          "textColor": "#BF360C"
        }
      },
      {
        "id": "description",
        "elementType": "text",
        "bindings": {
          "text": "Container height automatically adjusts to fit all children plus padding and spacing"
        },
        "layout": {
          "width": {
            "value": 100,
            "unit": "percent"
          },
          "height": {
            "value": "wrap_content",
            "unit": "dp"
          }
        },
        "style": {
          "fontSize": 16,
          "textColor": "#D84315",
          "lineHeight": 24
        }
      },
      {
        "id": "card-1",
        "elementType": "text",
        "bindings": {
          "text": "Card with variable text"
        },
        "layout": {
          "width": {
            "value": 100,
            "unit": "percent"
          },
          "height": {
            "value": "wrap_content",
            "unit": "dp"
          },
          "padding": {
            "all": 16
          }
        },
        "style": {
          "backgroundColor": "#FFFFFF",
          "borderRadius": 12,
          "fontSize": 18,
          "textColor": "#BF360C"
        }
      },
      {
        "id": "card-2",
        "elementType": "text",
        "bindings": {
          "text": "This card has much longer text that spans multiple lines and demonstrates how wrap_content adapts to content size dynamically."
        },
        "layout": {
          "width": {
            "value": 100,
            "unit": "percent"
          },
          "height": {
            "value": "wrap_content",
            "unit": "dp"
          },
          "padding": {
            "all": 16
          }
        },
        "style": {
          "backgroundColor": "#FFFFFF",
          "borderRadius": 12,
          "fontSize": 16,
          "textColor": "#D84315",
          "lineHeight": 24
        }
      },
      {
        "id": "card-3",
        "elementType": "text",
        "bindings": {
          "text": "Short text"
        },
        "layout": {
          "width": {
            "value": 100,
            "unit": "percent"
          },
          "height": {
            "value": "wrap_content",
            "unit": "dp"
          },
          "padding": {
            "all": 16
          }
        },
        "style": {
          "backgroundColor": "#FFFFFF",
          "borderRadius": 12,
          "fontSize": 18,
          "textColor": "#BF360C"
        }
      }
    ]
  }
}
